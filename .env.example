# ─── DATABASE ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/clieproxy?schema=public"

# ─── JWT & SESSION ────────────────────────────────────────────────────────────
JWT_SECRET="clieproxy-jwt-secret-ganti-ini-min-32-karakter"
SESSION_SECRET="clieproxy-session-secret-ganti-ini"

# ─── ENCRYPTION (untuk enkripsi API keys user) ───────────────────────────────
ENCRYPTION_KEY="clieproxy-enc-key-ganti-32-char!"

# ─── URLs ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
BASE_URL="https://[backend].up.railway.app"
FRONTEND_URL="https://[frontend].up.railway.app"

# ─── OAuth (opsional) ─────────────────────────────────────────────────────────
OAUTH_GOOGLE_CLIENT_ID=""
OAUTH_GOOGLE_CLIENT_SECRET=""
OAUTH_GITHUB_CLIENT_ID=""
OAUTH_GITHUB_CLIENT_SECRET=""
